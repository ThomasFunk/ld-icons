msgstr "Der Zielname existiert bereits."

msgid "Rename failed: {error}"
msgstr "Umbenennen fehlgeschlagen: {error}"

msgid "Please select exactly one item."
msgstr "Bitte genau ein Element auswählen."

msgid "Could not read file metadata: {error}"
msgstr "Dateimetadaten konnten nicht gelesen werden: {error}"

msgid "Delete '{name}' permanently?"
msgstr "'{name}' dauerhaft löschen?"

msgid "Delete {count} selected items permanently?"
msgstr "{count} ausgewählte Elemente dauerhaft löschen?"

msgid "Some items could not be deleted:\n{items}"
msgstr "Einige Elemente konnten nicht gelöscht werden:\n{items}"
