[Appearance]
# Colors in RGBA format
# UI font is read automatically from the active GTK theme (gtk-font-name);
# if that fails, fallback_font_path is used.
fallback_font_path = /usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
icon_size = 64
label_bg_color = 0, 0, 0, 0
# Hover/selection are derived from the active GTK theme if possible.
# These values override automatic detection.
hover_bg_color = 0, 102, 204, 220
selection_bg_color = 0, 102, 204, 255
label_text_color_hover = 255, 255, 255, 255
label_text_color_selected = 255, 255, 255, 255
label_text_color_normal = 255, 255, 255, 255
tooltip_bg_color = 255, 255, 200, 255

[Layout]
# Spacing between icons
grid_spacing_x = 140
grid_spacing_y = 180
# Grid fill direction: vertical (top->bottom), horizontal (left->right)
grid_direction = vertical
# Force wrap after N icons per column/row
# 0 = wrap only at desktop/monitor boundary
grid_wrap_count = 0
start_offset_x = 50
start_offset_y = 50
# Snap grid for drag & drop (fallback: grid_spacing_x/y)
snap_grid_x = 140
snap_grid_y = 180
# Snap grid origin
snap_origin_x = 50
snap_origin_y = 50

[Behavior]
# Time in seconds
tooltip_delay = 1.2
# Double-click time window for icons (single-click = select)
double_click_timeout = 0.3
# Snap icon to grid when releasing after drag
snap_to_grid = true
# Avoid occupied grid cells when snapping (find next free cell)
snap_avoid_overlap = true
# File for persistent icon positions
positions_file = ./icon_positions.json
# Layer-shell level: background | bottom | top | overlay
# For desktop icons above the wallpaper and below normal windows: bottom
# Note: 'top'/'overlay' may cover windows and change input behavior.
layer = bottom
# Input debug can be enabled via environment variable:
#   DESKICONS_INPUT_DEBUG=1 python3 -u dicons.py
# (Aliases still supported: PYDICONS_INPUT_DEBUG, DICONS_INPUT_DEBUG)